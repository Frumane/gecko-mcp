{
  "name": "floorp-mcp",
  "version": "1.1.0",
  "description": "An MCP server that lets AI assistants (Claude Code, Claude Desktop, Cursor…) read, screenshot and manage tabs in the Floorp browser via its built-in automation API.",
  "type": "module",
  "bin": {
    "floorp-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "probe": "tsx src/probe.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "floorp",
    "firefox",
    "browser",
    "automation",
    "claude"
  ],
  "author": "Arda Karaman (Frumane)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
